#!/usr/bin/env python3
"""st - skill-tree toolkit dispatcher.

usage: st [-C <dir>] <command> [args...]

Runs the sibling program st-<command>, git-style. `st help` lists commands.
"""
import os
import sys


def bindir():
    return os.path.dirname(os.path.realpath(__file__))


def commands():
    out = {}
    for f in sorted(os.listdir(bindir())):
        if f.startswith("st-"):
            path = os.path.join(bindir(), f)
            if os.access(path, os.X_OK):
                out[f[3:]] = path
    return out


def usage(code=0):
    print(__doc__.strip())
    print("\ncommands:")
    for name, path in commands().items():
        summary = ""
        try:
            with open(path) as f:
                for line in f:
                    if line.startswith('"""'):
                        summary = line.strip('"\n ').split(" - ", 1)[-1]
                        break
        except OSError:
            pass
        print("  %-8s %s" % (name, summary))
    sys.exit(code)


def main():
    args = sys.argv[1:]
    if args and args[0] == "-C":
        if len(args) < 2:
            usage(2)
        os.chdir(args[1])
        args = args[2:]
    if not args or args[0] in ("help", "-h", "--help"):
        usage(0)
    if args[0] in ("version", "--version"):
        sys.path.insert(0, os.path.join(bindir(), "..", "lib"))
        import skilltree
        print("st %s" % skilltree.__version__)
        sys.exit(0)
    cmds = commands()
    if args[0] not in cmds:
        print("st: unknown command %r (see `st help`)" % args[0],
              file=sys.stderr)
        sys.exit(2)
    os.execv(cmds[args[0]], [cmds[args[0]]] + args[1:])


if __name__ == "__main__":
    main()
