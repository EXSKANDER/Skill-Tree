#!/usr/bin/env python3
"""st-done - complete lesson problems, with optional evidence; learn nodes."""
import argparse
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)),
                                "..", "lib"))
from skilltree import actions
from skilltree import graph as graphmod
from skilltree import store


def main():
    ap = argparse.ArgumentParser(
        description=__doc__,
        epilog="Evidence can be any file (photo, audio, video, text...). "
               "For now it is stored as-is and the problem is marked "
               "complete without verification.")
    ap.add_argument("graph")
    ap.add_argument("node")
    ap.add_argument("problems", nargs="*",
                    help="problem ids like 1.2 (see `st node problems`)")
    ap.add_argument("--all", action="store_true",
                    help="complete every remaining problem of the node")
    ap.add_argument("-e", "--evidence", action="append", default=[],
                    metavar="FILE", help="attach an evidence file (repeatable)")
    ap.add_argument("--note", default="", help="short text note")
    ap.add_argument("--force", action="store_true",
                    help="allow completing a node whose prereqs are unlearned")
    args = ap.parse_args()

    root = store.find_root()
    cfg = store.config(root)
    nodes = graphmod.load_or_die(root, args.graph)
    progress = store.load_progress(root, args.graph)

    for f in args.evidence:
        if not os.path.isfile(f):
            store.die("evidence file not found: %s" % f)

    try:
        result = actions.complete(
            root, cfg, nodes, progress, args.graph, args.node,
            problems=args.problems or None, all_=args.all,
            evidence=args.evidence, note=args.note, force=args.force,
            today=store.today())
    except actions.ActionError as e:
        hint = " (--force to override)" if "not ready" in str(e) else ""
        store.die("%s%s" % (e, hint))

    for path in result["evidence"]:
        print("evidence stored: %s" % path)
    for msg in result["messages"]:
        print(msg)


if __name__ == "__main__":
    main()
