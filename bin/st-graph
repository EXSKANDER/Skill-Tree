#!/usr/bin/env python3
"""st-graph - create and list knowledge graphs."""
import argparse
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)),
                                "..", "lib"))
from skilltree import graph as graphmod
from skilltree import node as nodemod
from skilltree import store


def main():
    ap = argparse.ArgumentParser(description=__doc__)
    sub = ap.add_subparsers(dest="cmd", required=True)
    p_new = sub.add_parser("new", help="create an empty graph")
    p_new.add_argument("name")
    sub.add_parser("list", help="list graphs (name, nodes, learned)")
    args = ap.parse_args()

    root = store.find_root()
    if args.cmd == "new":
        if not nodemod.ID_RE.match(args.name):
            store.die("bad graph name %r (use lowercase letters, digits, -)"
                      % args.name)
        if os.path.isdir(store.graph_dir(root, args.name)):
            store.die("graph %s already exists" % args.name)
        os.makedirs(store.nodes_dir(root, args.name))
        os.makedirs(os.path.join(store.graph_dir(root, args.name), "media"))
        print("created graph %s" % args.name)
    else:
        for g in store.list_graphs(root):
            nodes, _ = graphmod.load(root, g)
            progress = store.load_progress(root, g)
            learned = sum(1 for n in nodes if store.is_learned(progress, n))
            print("%s\t%d nodes\t%d learned" % (g, len(nodes), learned))


if __name__ == "__main__":
    main()
