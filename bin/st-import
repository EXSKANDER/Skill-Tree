#!/usr/bin/env python3
"""st-import - ingest LLM-generated node bundles into a graph."""
import argparse
import os
import re
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)),
                                "..", "lib"))
from skilltree import graph as graphmod
from skilltree import node as nodemod
from skilltree import store

OPEN_RE = re.compile(r"^<<<node\s+([a-z0-9-]+)>>>\s*$")
CLOSE = "<<<end>>>"


def split_bundle(text):
    """Yield (node_id, node_file_text) from a bundle (see docs/PROMPT.md)."""
    blocks = []
    current = None
    for lineno, line in enumerate(text.split("\n"), 1):
        m = OPEN_RE.match(line.strip())
        if m:
            if current is not None:
                store.die("line %d: <<<node>>> before previous <<<end>>>"
                          % lineno)
            current = (m.group(1), [])
        elif line.strip() == CLOSE:
            if current is None:
                store.die("line %d: <<<end>>> without <<<node>>>" % lineno)
            blocks.append((current[0], "\n".join(current[1]).strip() + "\n"))
            current = None
        elif current is not None:
            current[1].append(line)
    if current is not None:
        store.die("unterminated <<<node %s>>> block" % current[0])
    return blocks


def main():
    ap = argparse.ArgumentParser(
        description=__doc__,
        epilog="Bundle format: each node wrapped in `<<<node <id>>>>` ... "
               "`<<<end>>>` lines, body = a complete node markdown file. "
               "docs/PROMPT.md has the matching LLM prompt formula.")
    ap.add_argument("graph")
    ap.add_argument("file", nargs="?", default="-",
                    help="bundle file (default: stdin)")
    ap.add_argument("--force", action="store_true",
                    help="overwrite existing node files")
    args = ap.parse_args()

    root = store.find_root()
    store.require_graph(root, args.graph)
    if args.file == "-":
        text = sys.stdin.read()
    else:
        with open(args.file) as f:
            text = f.read()

    blocks = split_bundle(text)
    if not blocks:
        store.die("no <<<node>>> blocks found in input")

    ndir = store.nodes_dir(root, args.graph)
    written = []
    for nid, body in blocks:
        path = os.path.join(ndir, nid + ".md")
        if os.path.exists(path) and not args.force:
            store.die("node %s already exists (--force to overwrite)" % nid)
        store.write_atomic(path, body)
        try:
            nodemod.parse(path)
        except nodemod.NodeError as e:
            os.unlink(path)
            store.die("rejected %s: %s (nothing else was imported after it)"
                      % (nid, e))
        written.append(nid)
        print("imported %s" % nid)

    nodes, errors = graphmod.load(root, args.graph)
    errors += graphmod.check(nodes)
    for e in errors:
        print("warning: %s" % e, file=sys.stderr)
    print("%d node%s imported into %s%s"
          % (len(written), "s" if len(written) != 1 else "", args.graph,
             "; run `st check %s` after fixing warnings" % args.graph
             if errors else ""))


if __name__ == "__main__":
    main()
